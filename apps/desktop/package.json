{
  "name": "@veyra/desktop",
  "version": "1.0.0",
  "description": "Veyra Desktop Application",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.veyra.desktop",
    "productName": "Veyra",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
