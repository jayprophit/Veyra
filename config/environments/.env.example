# Veyra Environment Configuration
# ===========================================
# Copy this file to .env and fill in your API keys

# ============================================================================
# DATA PROVIDERS
# ============================================================================

# Polygon.io - Real-time US stock data (https://polygon.io/)
POLYGON_API_KEY=your_polygon_api_key_here

# Alpaca - Trading execution (https://alpaca.markets/)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper for testing

# Alpha Vantage - Market data (https://www.alphavantage.co/)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Coinbase Pro - Crypto trading
COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET=your_coinbase_secret
COINBASE_PASSPHRASE=your_coinbase_passphrase

# Interactive Brokers (optional)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ============================================================================
# AI/ML SERVICES
# ============================================================================

# OpenAI - GPT-4 for earnings analysis and generative reports
OPENAI_API_KEY=your_openai_key

# Anthropic - Claude for alternative analysis
ANTHROPIC_API_KEY=your_anthropic_key

# Hugging Face - Open source models
HUGGINGFACE_API_TOKEN=your_hf_token

# ============================================================================
# DATABASE & CACHE
# ============================================================================

# PostgreSQL (production) or SQLite (development)
DATABASE_URL=sqlite:///data/veyra.db
# DATABASE_URL=postgresql://user:pass@localhost/veyra

# Redis - Caching and real-time data
REDIS_URL=redis://localhost:6379

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret for API authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption key for sensitive data
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Data source: 'live' for real APIs, 'mock' for simulated data
DATA_SOURCE=mock

# Enable/disable features
ENABLE_WEBSOCKET=true
ENABLE_AI_ANALYSIS=true
ENABLE_REAL_TRADING=false  # Set to true only for production with real money
ENABLE_PAPER_TRADING=true

# ============================================================================
# MONITORING
# ============================================================================

# Sentry - Error tracking (optional)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Prometheus metrics port
METRICS_PORT=9090

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# WEB3/DEFI (Optional)
# ============================================================================

# Ethereum node (Infura, Alchemy, or local)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id

# Wallet for DeFi interactions (optional)
WALLET_ADDRESS=0x...
WALLET_PRIVATE_KEY=0x...  # Keep secure!

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Telegram bot for notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Plaid - Bank account syncing (https://plaid.com/)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox  # sandbox or production

# ============================================================================
# DEVELOPMENT
# ============================================================================

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true  # Auto-reload for development

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
