# Financial Master - Local Development Environment
# ================================================
# This file is for LOCAL TESTING with mock data and paper trading

# ============================================
# ENVIRONMENT SETTING
# ============================================
ENVIRONMENT=local
DEBUG=true
USE_MOCK_DATA=true
LOG_LEVEL=INFO

# ============================================
# DATABASE (SQLite for local)
# ============================================
DB_TYPE=sqlite
SQLITE_PATH=./data/financial_master.db

# For testing with Neon PostgreSQL (optional)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:pass@neon-host/dbname

# ============================================
# API SERVER
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8765
WS_MOCK_UPDATE_INTERVAL=2.0

# ============================================
# DATA PROVIDERS (FREE TIERS)
# ============================================

# Finnhub - Real-time US stocks (60 calls/min free)
# Get API key at: https://finnhub.io/register
FINNHUB_API_KEY=

# Polygon.io - Market data (5 API calls/min free)
# Get API key at: https://polygon.io/
POLYGON_API_KEY=

# Alpha Vantage - Stock data (25 calls/day free)
# Get API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance (no key needed - used via yfinance library)

# ============================================
# PAPER TRADING - ALPACA (FREE)
# ============================================
# Get paper trading keys at: https://alpaca.markets/
# Paper trading is FREE and unlimited
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_PAPER=true

# Live trading keys (ONLY when ready for real money)
# ALPACA_LIVE_API_KEY=
# ALPACA_LIVE_API_SECRET=
# ALPACA_PAPER=false

# ============================================
# OTHER BROKERS (Paper Trading Modes)
# ============================================

# Interactive Brokers Paper Trading
# Requires IB Gateway or TWS running locally
IB_PAPER_ACCOUNT=true
IB_HOST=127.0.0.1
IB_PORT=7497  # 7496 for TWS, 7497 for IB Gateway
IB_CLIENT_ID=1

# Trading212 (Demo mode available in app)
TRADING212_API_KEY=
TRADING212_DEMO=true

# ============================================
# LLM / AI CONFIGURATION (Free Tier)
# ============================================

# Ollama (Local, completely free)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_FALLBACK=false

# OpenAI (optional - paid)
# OPENAI_API_KEY=
# USE_PAID_LLM=false

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
SECRET_KEY=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# TRADING GUARDRAILS (Safety Limits)
# ============================================
MAX_DAILY_TRADES=5
APPROVAL_THRESHOLD=10000
ENABLE_KILL_SWITCH=true

# ============================================
# MONITORING (Free Tiers)
# ============================================

# Sentry (5,000 errors/month free)
# SENTRY_DSN=

# UptimeRobot (50 monitors free)
# UPTIMEROBOT_API_KEY=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AGENTS=true
ENABLE_TAX_OPTIMIZATION=true
ENABLE_RETIREMENT_PLANNING=true
ENABLE_RISK_MANAGEMENT=true
ENABLE_PAPER_TRADING_ONLY=true
