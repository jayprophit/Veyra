# Financial Master - Staging Environment (Cloud Testing)
# =======================================================
# This file is for STAGING/DEMO deployment with paper trading
# All real money trading is DISABLED in this environment

# ============================================
# ENVIRONMENT SETTING
# ============================================
ENVIRONMENT=staging
DEBUG=false
USE_MOCK_DATA=false
LOG_LEVEL=INFO

# ============================================
# DATABASE (Neon PostgreSQL - Free Tier)
# ============================================
DB_TYPE=postgres
DATABASE_URL=${DATABASE_URL}  # Set in Render/GitHub secrets

# ============================================
# API SERVER
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765
WS_MOCK_UPDATE_INTERVAL=2.0

# ============================================
# DATA PROVIDERS (FREE TIERS)
# ============================================

# Priority: Use real data in staging
FINNHUB_API_KEY=${FINNHUB_API_KEY}
POLYGON_API_KEY=${POLYGON_API_KEY}
ALPHA_VANTAGE_API_KEY=${ALPHA_VANTAGE_API_KEY}

# ============================================
# PAPER TRADING - ALPACA (MANDATORY IN STAGING)
# ============================================
# Paper trading is REQUIRED for staging - no live trading allowed
ALPACA_PAPER_API_KEY=${ALPACA_PAPER_API_KEY}
ALPACA_PAPER_API_SECRET=${ALPACA_PAPER_API_SECRET}
ALPACA_PAPER=true

# ============================================
# LLM / AI CONFIGURATION
# ============================================
OLLAMA_HOST=${OLLAMA_HOST:-http://localhost:11434}
OLLAMA_MODEL=${OLLAMA_MODEL:-llama3.2:3b}

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
SECRET_KEY=${SECRET_KEY}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# TRADING GUARDRAILS (Stricter in staging)
# ============================================
MAX_DAILY_TRADES=3
APPROVAL_THRESHOLD=5000
ENABLE_KILL_SWITCH=true

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=${SENTRY_DSN}

# ============================================
# FEATURE FLAGS (Staging overrides)
# ============================================
ENABLE_AGENTS=true
ENABLE_TAX_OPTIMIZATION=true
ENABLE_RETIREMENT_PLANNING=true
ENABLE_RISK_MANAGEMENT=true
ENABLE_PAPER_TRADING_ONLY=true
FORCE_PAPER_TRADING=true
