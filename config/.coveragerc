# Coverage configuration for Veyra
[run]
branch = True
source = src
data_file = .coverage

[report]
precision = 2
show_missing = True
skip_covered = False
skip_empty = True

# Patterns to exclude from coverage
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abstract
    if 0:
    if False:

[html]
directory = htmlcov
title = Veyra - Code Coverage Report

[xml]
output = coverage.xml
