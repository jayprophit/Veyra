# Veyra - Environment Configuration
# =============================================
# Copy this file to .env and fill in your actual API keys
# This enables LIVE data instead of mock data

# =============================================================================
# DATA SOURCE CONFIGURATION
# =============================================================================

# Options: 'live' (default), 'cached', 'mock'
# 'live' = Use real APIs (requires API keys below)
# 'cached' = Use cached data with API fallback
# 'mock' = Use mock data only (for testing)
DATA_SOURCE=live

# =============================================================================
# POLYGON.IO - Real-Time Market Data (Recommended)
# =============================================================================
# Get your free API key at: https://polygon.io/
# Free tier: 5 API calls/minute
# Paid tier: Unlimited ($49/month)
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# ALPACA - Trading & Account Data
# =============================================================================
# Sign up at: https://alpaca.markets/
# Paper trading is FREE and uses fake money
# Live trading requires identity verification
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper Trading (safe for testing)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADING=true

# Live Trading (REAL MONEY - use with caution!)
# ALPACA_BASE_URL=https://api.alpaca.markets
# ALPACA_PAPER_TRADING=false

# =============================================================================
# ALPHA VANTAGE - Alternative Data Source (Free Tier)
# =============================================================================
# Get free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Real-time price updates via WebSocket
ENABLE_REALTIME_PRICES=true

# Live trading capability (requires ALPACA_LIVE)
ENABLE_LIVE_TRADING=false

# Auto-refresh dashboard data
ENABLE_AUTO_REFRESH=true

# Cache settings
CACHE_ENABLED=true
CACHE_TTL=30

# WebSocket settings
WS_ENABLED=true
WS_REFRESH_INTERVAL=5

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///veyra.db

# =============================================================================
# SECURITY
# =============================================================================
# Generate a secure secret key for session management
SECRET_KEY=your_secure_random_string_here

# JWT settings
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# DEVELOPMENT / DEBUG
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO

# Test mode (uses mock data regardless of API keys)
# TEST_MODE=false
