# Financial Master - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_TYPE=sqlite                    # Options: sqlite, postgres, timescale
SQLITE_PATH=./data/financial_master.db

# PostgreSQL (optional - for scalable tier)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=finmaster
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=financial_master

# ============================================
# LLM CONFIGURATION (FREE TIER)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b          # Fast, good for summaries
OLLAMA_FALLBACK_MODEL=llama3.1:8b  # Better reasoning

# Paid LLM Fallback (optional)
USE_PAID_LLM=false
OPENAI_API_KEY=sk-...             # Optional: GPT-4o-mini
ANTHROPIC_API_KEY=sk-ant-...      # Optional: Claude Haiku

# ============================================
# DATA FEEDS (FREE TIER)
# ============================================
USE_MOCK_DATA=true                # Use mock data if no API keys
FINNHUB_API_KEY=your_finnhub_key  # Get free at finnhub.io
POLYGON_API_KEY=your_polygon_key  # Get free at polygon.io
ALPACA_API_KEY=your_alpaca_key    # Get free at alpaca.markets
ALPACA_SECRET_KEY=your_secret

# ============================================
# SECURITY & GUARDRAILS
# ============================================
MAX_DAILY_TRADES=5
APPROVAL_THRESHOLD=10000          # £10k+ requires human approval
MAX_DAILY_VALUE=100000            # £100k daily limit
DAILY_LOSS_LIMIT=5000             # £5k max daily loss

# ============================================
# TELEGRAM BOT (OPTIONAL)
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================
# API SERVER
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
WEBSOCKET_PORT=8765
DEBUG=false

# ============================================
# TAX CONFIGURATION (UK)
# ============================================
CGT_ALLOWANCE=3000                # 2024-25 allowance
ISA_ALLOWANCE=20000               # Annual ISA limit
SIPP_ALLOWANCE=60000              # Annual SIPP limit
TAX_YEAR_START=2024-04-06

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AGENTS=true
ENABLE_WEBSOCKET=true
ENABLE_TAX_HARVESTING=true
ENABLE_AUTO_REBALANCE=false       # Auto-rebalance requires approval
ENABLE_MOCK_DATA=true

# ============================================
# PATHS
# ============================================
DATA_DIR=./data
LOGS_DIR=./logs
MODELS_DIR=./models
BACKUP_DIR=./backups
